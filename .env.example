# 服务器端口
PORT=3000

# 天气位置 (Open-Meteo, 无需 API Key)
# 上海: 31.23, 121.47
# 北京: 39.91, 116.39
# 深圳: 22.54, 114.05
WEATHER_LAT=31.23
WEATHER_LON=121.47
WEATHER_TIMEZONE=Asia/Shanghai
WEATHER_CITY=上海

# 股票代码 (Yahoo Finance 格式, 逗号分隔)
# A股: 600519.SS (茅台), 000001.SZ (平安银行)
# 港股: 0700.HK (腾讯)
# 美股: AAPL, MSFT, TSLA
# 指数: ^GSPC (标普500), ^HSI (恒指), 000001.SS (上证指数)
STOCK_SYMBOLS=600519.SS,0700.HK,^GSPC

# 页面自动刷新间隔 (秒)，Kindle 每隔此时间重新拉取
REFRESH_INTERVAL=900

# ── Vercel 部署专用 ──────────────────────────────────────────
# Vercel Blob 存储 token（在 Vercel 控制台 Storage → Blob 创建后获取）
BLOB_READ_WRITE_TOKEN=

# Cron 接口鉴权 secret（可选，防止外部随意触发 /api/cron/screenshot）
# 设置后 cron 请求需携带 Authorization: Bearer <secret>
CRON_SECRET=

# Cron 截图间隔（分钟），仅供参考，实际由 vercel.json cron schedule 控制
SCREENSHOT_INTERVAL_MIN=30
